# Server
PORT=5000
NODE_ENV=production

# NeonDB — copy from your Neon dashboard > Connection String
DATABASE_URL=postgresql://neondb_owner:npg_20BmTVLKzQeP@ep-lingering-wave-apn4y4sz-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT — generate a long random string: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback

# Frontend URL (for CORS + OAuth redirect after login)
FRONTEND_URL=https://your-ngo.vercel.app

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# File Uploads (served from VPS)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
